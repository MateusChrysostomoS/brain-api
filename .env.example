# --- Application ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- Database (asyncpg driver) — brain's own database in the shared Postgres ---
DATABASE_URL=postgresql+asyncpg://brain:brain@localhost:5432/brain

# --- JWT (identity authority) ---
# HS256 signing key. SHARED mesh secret (precheck verifies brain tokens with the
# same key). Generate with: openssl rand -hex 64
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
# Access-token lifetime in minutes (keep short).
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Lifetime of the minted PreCheck SSO handoff token (POST /sso/precheck/token).
PRECHECK_TOKEN_EXPIRE_MINUTES=60

# --- CORS (the Next.js Brain portal) ---
# Comma-separated list of allowed browser origins.
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Demo request anti-spam ---
DEMO_RATE_LIMIT_PER_MIN=5

# --- Platform admin bootstrap (scripts/seed_admin.py) ---
# The single platform admin seeded into a fresh DB (role=admin, tenant_id=NULL).
# Read ONLY from the environment; the password is bcrypt-hashed on insert, never stored
# in code or logged. The seed is idempotent (skips if the email already exists).
ADMIN_EMAIL=admin@brain.co
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- Admin "Modo médico" impersonation (POST /admin/impersonate/token, CONTRACTS §11.4) ---
# Clinic (tenant) owner the admin header's "Modo médico" switch enters, so an admin can use
# the doctor portal + PreCheck/secretarIA with real data while developing. Must be a
# tenant_owner/tenant_staff that carries a tenant_id (else the endpoint returns 404).
# Defaults to the seeded dev clinic; in production point it at a real sandbox clinic owner.
IMPERSONATION_DEMO_EMAIL=dra.demo@clinica.com.br

# --- Service-to-service: BFF proxy into PreCheck ---
# Base URL of the PreCheck backend (e.g. http://precheck:8000 on the internal network).
# Empty disables the upstream call: admin "inbound" + doctor "anamneses" then return an
# empty page locally. brain-api forwards the caller's brain JWT (precheck validates it).
PRECHECK_BASE_URL=
# Timeout (seconds) for the precheck proxy client.
PRECHECK_TIMEOUT_SECONDS=10

# --- Service-to-service: secretaria (internal-only) ---
# Base URL of secretaria on the internal network (e.g. http://secretaria:8000). Empty in
# dev → /doctor/appointments + /doctor/patients return an empty page (no upstream call).
SECRETARIA_BASE_URL=
# ACTIVE: X-Internal-Api-Key for brain-api -> secretaria /internal/* (doctor appointments
# + patients). MUST equal secretaria's OWN INTERNAL_API_KEY byte-for-byte, else secretaria
# returns 401/403 and brain-api surfaces 502. Generate a random machine secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Empty here fails closed to an empty page. NEVER log it. Different from SECRETARIA_ADMIN_TOKEN below.
SECRETARIA_API_KEY=

# --- secretaria admin (cross-API into secretaria's /admin/*) ---
# secretaria has NO user/role system; its only privileged surface is /admin/*, guarded by
# the X-Admin-Token header checked against secretaria's OWN ADMIN_TOKEN env var. This is a
# DIFFERENT mechanism from INTERNAL_API_KEY above, so it needs its own value. It MUST equal
# secretaria's ADMIN_TOKEN byte-for-byte or secretaria returns 403; empty here fails closed
# (brain-api raises 503 before any call). Guards a DESTRUCTIVE wipe endpoint — NEVER log it.
SECRETARIA_ADMIN_TOKEN= 
# Timeout (seconds) for the secretaria admin client.
SECRETARIA_TIMEOUT_SECONDS=10
